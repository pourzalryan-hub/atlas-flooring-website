# ── Resend (email notifications) ─────────────────────────────────
# Sign up at resend.com, verify atlasrugflooring.com domain, create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Make.com webhook (Google Sheets lead logging) ─────────────────
# Full setup steps in INTEGRATIONS_SETUP.md
# Get this URL from Make.com → your scenario → Webhook module → Copy URL
MAKE_WEBHOOK_URL=https://hook.eu2.make.com/xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Tag Manager ────────────────────────────────────────────
# Your GTM container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# ── Resend (email notifications) ─────────────────────────────────
# Sign up at resend.com, verify atlasrugflooring.com domain, create an API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Sheets (lead logging) ─────────────────────────────────
# Full instructions in INTEGRATIONS_SETUP.md

# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART_HERE/edit
GOOGLE_SHEET_ID=your_sheet_id_here

# From the downloaded service account JSON key — the "client_email" field
GOOGLE_SERVICE_ACCOUNT_EMAIL=atlas-leads@your-project.iam.gserviceaccount.com

# From the downloaded service account JSON key — the "private_key" field
# Keep the \n characters exactly as they appear in the JSON — do not add real line breaks
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----\n"

# ── Google Tag Manager ────────────────────────────────────────────
# Your GTM container ID (e.g. GTM-XXXXXXX)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
